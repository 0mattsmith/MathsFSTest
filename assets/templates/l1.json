        { "name": "b", "type": "int", "min": 2,  "max": 9 },
        { "name": "c", "type": "int", "min": 2,  "max": 6 }
      ],
      "stem": "Work out ({{a}} + {{b}}) ÷ {{c}} (give whole-number answer if it divides exactly, otherwise to 1 d.p.)",
      "answer": "{{((a + b) / c).toFixed(1).replace(/\\.0$/,'')}}"
