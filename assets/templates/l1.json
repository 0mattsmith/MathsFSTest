        { "name": "b", "type": "int", "min": 3,  "max": 8 },
        { "name": "c", "type": "int", "min": 2,  "max": 9 }
      ],
      "stem": "Work out {{a}} + {{b}} × {{c}}",
      "answer": "{{a + b * c}}"
