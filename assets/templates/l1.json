  "templates": [
    {
      "id": "l1-tpl-round-100", "topic": "n.order", "strand": "number", "calc": false, "marks": 1, "type": "input",
      "params": [ { "name": "n", "type": "int", "min": 1234, "max": 9876 } ],
      "stem": "Round {{n}} to the nearest 100.",
      "answer": "{{Math.round(n/100) * 100}}"
    },
    {
      "id": "l1-tpl-round-1000", "topic": "n.approx", "strand": "number", "calc": false, "marks": 1, "type": "input",
      "params": [ { "name": "n", "type": "int", "min": 2345, "max": 9876 } ],
      "stem": "Round {{n}} to the nearest 1 000.",
      "answer": "{{Math.round(n/1000) * 1000}}"
    },
    {
