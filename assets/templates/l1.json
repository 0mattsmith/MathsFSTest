    },
    {
      "id": "l1-tpl-pct-25", "topic": "n.pct", "strand": "number", "calc": false, "marks": 2, "type": "input",
      "params": [
        { "name": "n4", "type": "int", "min": 8, "max": 120, "step": 4 }
      ],
      "stem": "Work out 25% of {{n4 * 4}}",
